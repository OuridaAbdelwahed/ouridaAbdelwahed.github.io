---
import { Header } from '@/components/layout/Header';
import { MotionOrchestrator } from '@/components/animations/MotionOrchestrator';
import { PageLoader } from '@/components/animations/PageLoader';
import FloatingSocials from '@/components/ui/FloatingSocials.astro';
import { navigation } from '@/data/navigation';
import { personal, socialLinks } from '@/data/personal';
import { withBase } from '@/utils/paths';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${personal.name} — Data Engineering, AI & Full-Stack Development`,
  description = personal.introduction,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const ogImage = new URL(withBase(base, personal.heroCasaDesktop), Astro.site ?? Astro.url.origin);
const cvHref = withBase(base, personal.cvPath);
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: personal.name,
  jobTitle: personal.role,
  description: personal.profile,
  email: `mailto:${personal.email}`,
  telephone: personal.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Errachidia',
    addressCountry: 'MA',
  },
  url: canonical.toString(),
  sameAs: socialLinks.map((link) => link.href),
};
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070b14" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase(base, 'favicon.svg')} />
    <link rel="manifest" href={withBase(base, 'site.webmanifest')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Manrope:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`Portrait of ${personal.name}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.replace('no-js', 'js');
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <PageLoader client:load />
    <Header navigation={navigation} cvHref={cvHref} client:load />
    <FloatingSocials />
    <slot />
    <MotionOrchestrator client:load />
    <div class="page-grain" aria-hidden="true"></div>
  </body>
</html>

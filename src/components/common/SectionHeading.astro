---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  description?: string;
  align?: 'left' | 'split';
}

const { index, eyebrow, title, description, align = 'split' } = Astro.props;
---

<header class:list={['section-heading', `section-heading--${align}`]} data-reveal>
  <div class="section-kicker">
    <span>{index}</span>
    <p>{eyebrow}</p>
  </div>
  <div>
    <h2>{title}</h2>
    {description && <p class="section-description">{description}</p>}
  </div>
</header>
